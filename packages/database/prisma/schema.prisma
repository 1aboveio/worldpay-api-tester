generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys       ApiKey[]
  paymentMethods PaymentMethod[]
}

model ApiKey {
  id         String   @id @default(cuid())
  key        String   @unique
  prefix     String
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  createdAt  DateTime @default(now())
  expiresAt  DateTime?

  @@index([key])
  @@index([merchantId])
}

model PaymentMethod {
  id                String   @id
  merchantId        String
  merchant          Merchant @relation(fields: [merchantId], references: [id])
  worldpayTokenHref String
  idempotencyKey    String?
  brand             String
  last4             String
  expiryMonth       Int
  expiryYear        Int
  funding           String
  country           String?
  status            String   @default("active")
  createdAt         DateTime @default(now())

  @@unique([merchantId, idempotencyKey])
  @@index([merchantId])
}
