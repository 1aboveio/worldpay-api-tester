generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id             String           @id @default(cuid())
  name           String
  entity         String           @unique
  payFacConfig   Json
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  apiKeys        ApiKey[]
  paymentMethods PaymentMethod[]
  paymentIntents PaymentIntent[]
}

model ApiKey {
  id         String   @id @default(cuid())
  keyHash    String   @unique
  prefix     String
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PaymentMethod {
  id            String           @id
  merchantId    String
  merchant      Merchant         @relation(fields: [merchantId], references: [id])
  type          String           @default("card")
  tokenHref     String
  brand         String?
  last4         String?
  expiryMonth   Int?
  expiryYear    Int?
  funding       String?
  country       String?
  cardholderName String?
  billingAddress Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  paymentIntents PaymentIntent[]
}

enum PaymentIntentStatus {
  created
  processing
  tokenizing
  tokenized
  risk_assessing
  risk_assessed
  authorizing
  requires_capture
  succeeded
  canceled
  payment_failed
}

model PaymentIntent {
  id               String                @id
  merchantId       String
  merchant         Merchant              @relation(fields: [merchantId], references: [id])
  amount           Int
  currency         String
  status           PaymentIntentStatus   @default(created)
  captureMethod    String                @default("automatic")
  paymentMethodId  String?
  paymentMethod    PaymentMethod?        @relation(fields: [paymentMethodId], references: [id])
  worldpayPaymentId String?
  schemeReference  String?
  linkData         Json?
  threeDSStatus    String?
  failureCode      String?
  failureMessage   String?
  metadata         Json?
  idempotencyKey   String?
  description      String?
  statementDescriptor String?
  setupFutureUsage String?
  customerEmail    String?
  customerIpAddress String?
  shipping         Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

// Better Auth models
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String  @id @default(cuid())
  userId                String
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId            String
  accountId             String
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id        String   @id @default(cuid())
  identifier String
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Portal models
model UserMerchant {
  id         String   @id @default(cuid())
  userId     String
  merchantId String
  role       String
  createdAt  DateTime @default(now())

  @@unique([userId, merchantId])
}

model Refund {
  id               String   @id @default(cuid())
  merchantId       String
  paymentIntentId  String
  amount           Int
  currency         String
  reason           String?
  status           String
  worldpayRefundId String?
  idempotencyKey   String?
  createdAt        DateTime @default(now())
}

model Statement {
  id                String   @id @default(cuid())
  merchantId        String?
  periodStart       DateTime?
  periodEnd         DateTime?
  totalVolume       Int?
  status            String?
  createdAt         DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  merchantId String?
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
}
