# Worldpay Access Test Environment Credentials
# Copy this file to .env and fill in your credentials
WORLDPAY_USERNAME=your_username
WORLDPAY_PASSWORD=your_password

# Base URL for test environment
WORLDPAY_BASE_URL=https://try.access.worldpay.com

# Your merchant entity reference (provided by Worldpay Implementation Manager)
WORLDPAY_ENTITY=your_entity

# Payment Facilitator scheme ID (from Visa/Mastercard/Amex)
WORLDPAY_PAYFAC_SCHEME_ID=12345

# API content type (versioned media type for Card Payments v7)
WORLDPAY_PAYMENTS_MEDIA_TYPE=application/vnd.worldpay.payments-v7+json

# API content type for Payment Queries v1
WORLDPAY_QUERIES_MEDIA_TYPE=application/vnd.worldpay.payment-queries-v1.hal+json
