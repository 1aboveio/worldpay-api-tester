DATABASE_URL="postgres://test:test@localhost:5432/worldpay_gateway"
ALLOWED_EMAIL_DOMAIN=fmmpay.com
# Set to "require" (or true) ONLY when connecting to Cloud SQL over TCP (private/
# public IP), which mandates SSL. Leave unset for plain Postgres (local/CI), which
# does not support SSL. Ignored for Cloud Run's unix-socket connections.
# DATABASE_SSL=require

# Better Auth — base URL of this app (used for absolute links, e.g. checkout URLs)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
ENCRYPTION_KEY=

# Worldpay Access — server-to-server credentials (HTTP Basic Auth)
WORLDPAY_BASE_URL=https://try.access.worldpay.com
WORLDPAY_USERNAME=
WORLDPAY_PASSWORD=
# Worldpay Access Checkout (hosted fields) identity — a Worldpay-provisioned UUID.
# Required for the checkout playground's public pay page. The page's origin must
# also be allowlisted with Worldpay (e.g. http://localhost:3000 and your Cloud Run URL).
WORLDPAY_CHECKOUT_ID=
