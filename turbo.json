{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"]
    },
    "db:push": {
      "dependsOn": ["db:generate"]
    },
    "test": {
      "dependsOn": ["^db:generate"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^db:generate"]
    }
  }
}
